# Example environment variables for secrets
# Telegram bot token (get from BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_token_here

# Solana wallet private key in base58 or json array
WALLET_PRIVATE_KEY_BASE58=your_base58_private_key_here

# Helius API key
HELIUS_API_KEY=your_helius_api_key

# ERPC/Yellowstone endpoint
YELLOWSTONE_GRPC_URL=https://your-erpc-endpoint

# Optional Jito API key
JITO_API_KEY=your_jito_api_key
